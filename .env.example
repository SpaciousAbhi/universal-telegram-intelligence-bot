BOT_TOKEN=123456:replace_me
OWNER_ID=123456789
MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net/?retryWrites=true&w=majority

# Accepted aliases:
# BOT_TOKEN can also be TELEGRAM_BOT_TOKEN or TOKEN
# OWNER_ID can also be ADMIN_ID or BOT_OWNER_ID
# MONGO_URI can also be MONGO_URL, MONGO_DB_URL, MONGO_DBURL, MONGODB_URI, MONGODB_URL, or MONGODBURL

